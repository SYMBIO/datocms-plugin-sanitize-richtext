{
  "name": "datocms-plugin-sanitize-richtext",
  "homepage": "https://github.com/SYMBIO/datocms-plugin-sanitize-richtext",
  "version": "0.1.4",
  "description": "Remove styles copied from MS Word and others",
  "main": "public/bundle.js",
  "scripts": {
    "start": "concurrently \"yarn dev\" \"yarn localtunnel\"",
    "localtunnel": "lt -s datocms-plugin-datocms-plugin-sanitize-richtext --port 5000",
    "dev": "NODE_ENV=development webpack-dev-server",
    "dist": "NODE_ENV=production webpack --progress",
    "build": "NODE_ENV=production webpack --progress",
    "prepublishOnly": "rimraf lib public && mkdir public && npm run dist",
    "addToProject": "yo datocms-plugin:add-to-project",
    "lint": "eslint src",
    "test": "node test/sanitize.test.js"
  },
  "keywords": [
    "datocms",
    "datocms-plugin",
    "field-addon",
    "text-field"
  ],
  "files": [
    "public",
    "docs"
  ],
  "author": "SYMBIO <dev@symbio.agency>",
  "license": "ISC",
  "engines": {
    "node": ">=16"
  },
  "datoCmsPlugin": {
    "title": "Sanitize Richtext",
    "previewImage": "docs/preview.gif",
    "coverImage": "docs/cover.png",
    "entryPoint": "public/index.html",
    "parameters": {
      "global": [],
      "instance": []
    }
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/register": "^7.29.7",
    "babel-loader": "9",
    "concurrently": "^5.3.0",
    "css-loader": "^7.1.4",
    "eslint": "^7.10.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-import-resolver-webpack": "^0.13.0",
    "eslint-plugin-import": "^2.22.1",
    "generator-datocms-plugin": "^1.0.26",
    "html-webpack-plugin": "5",
    "localtunnel": "^2.0.0",
    "serve": "^11.3.2",
    "style-loader": "^4.0.0",
    "webpack": "5",
    "webpack-cli": "5",
    "webpack-dev-server": "5",
    "yo": "^3.1.1"
  },
  "dependencies": {
    "datocms-plugin-sdk": "^2.1.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanitize-html": "^2.17.4"
  }
}
