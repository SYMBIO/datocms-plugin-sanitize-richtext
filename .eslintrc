{
  "parser": "@babel/eslint-parser",
  "parserOptions": {
    "requireConfigFile": false,
    "babelOptions": {
      "presets": [["@babel/preset-react", { "runtime": "automatic" }]]
    }
  },
  "extends": "airbnb-base",
  "env": {
    "es6": true,
    "browser": true
  },
  "settings": {
    "import/resolver": "webpack"
  },
  "rules": {
    "no-console": 0,
    "no-restricted-syntax": 0,
    "react/prop-types": 0
  }
}
